# ─── MySQL (Docker) ─────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=pz_db
MYSQL_USER=pz_user
MYSQL_PASSWORD=pz_pass
MYSQL_PORT=3306

# The Node.js server can read connection params either from DATABASE_URL
# or from the individual MYSQL_* variables above. DATABASE_URL wins.
# Example: DATABASE_URL=mysql://pz_user:pz_pass@db:3306/pz_db
DATABASE_URL=

# ─── Auth ──────────────────────────────────────────────────────────────────
# A long random string — generate one with `openssl rand -hex 32`
JWT_SECRET=1f0021e24a362bbde72b0248bd86d1fdbbc775d66cfcdf097d130ea18903f972
DEV_BYPASS_AUTH=true
GOOGLE_CLIENT_ID=

# ─── Photo storage ─────────────────────────────────────────────────────────
# PHOTOS_BACKEND=local  stores files on disk in PHOTOS_LOCAL_DIR (default).
# PHOTOS_BACKEND=s3     uses the S3_* variables below (works with MinIO, AWS
#                       S3, and Cloudflare R2's S3-compatible API).
PHOTOS_BACKEND=local
PHOTOS_LOCAL_DIR=./storage
PHOTOS_PUBLIC_URL=

# S3 / MinIO / R2 (S3-compatible)
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=

# ─── Self-hosted server ────────────────────────────────────────────────────
APP_PORT=8787
PORT=8787
HOST=0.0.0.0
STATIC_DIR=./dist/client
