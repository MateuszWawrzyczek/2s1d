{
  "name": "pz-worker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "docker compose up --build",
    "validate:docker": "node scripts/validate-docker-env.mjs",
    "build": "vite build",
    "start": "node scripts/validate-docker-env.mjs && node --import tsx src/server.ts",
    "notifications:run": "node --import tsx src/jobs/run-notifications.ts",
    "client:dev": "vite",
    "setup": "corepack pnpm install",
    "db:start": "docker compose up -d db",
    "db:wait": "node scripts/wait-for-mysql.mjs",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "node --import tsx src/db/seed-defaults.ts",
    "db:generate": "drizzle-kit generate",
    "test": "vitest run --config vitest.logic.config.ts && vitest run --config vitest.client.config.ts",
    "test:logic": "vitest run --config vitest.logic.config.ts",
    "test:client": "vitest run --config vitest.client.config.ts",
    "check": "tsc --noEmit",
    "lint": "eslint .",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}' 'tests/**/*.ts'"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "@hono/node-server": "^2.0.5",
    "@hono/zod-validator": "^0.8.0",
    "drizzle-orm": "^0.45.2",
    "esbuild": "^0.28.1",
    "hono": "^4.12.25",
    "jspdf": "^4.2.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.17.0",
    "mysql2": "^3.22.5",
    "papaparse": "^5.5.4",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.17.0",
    "read-excel-file": "^9.2.0",
    "tsx": "^4.22.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.9.2",
    "@types/papaparse": "^5.3.16",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitejs/plugin-react": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "jsonc-parser": "^3.3.1",
    "prettier": "^3.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@11.5.3+sha512.7ac1c919341c213a34dc0d02afb7143c5c26ac26ee8c4782deea821b8ac64d2134a081fd8941dae6e29bbb48f58dfc2b7fbceeccc07cb2f09d219d342a4969ed"
}
